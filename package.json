{
  "name": "webdriverIO",
  "type": "module",
  "scripts": {
    "wdio": "wdio run wdio.conf.ts",
    "env:prod": "cross-env ENV=prod wdio",
    "suite:login": "wdio --suite login",
    "test:api": "cross-env HEADLESS=true ENV=test wdio --suite api",
    "tag:login": "wdio --mochaOpts.grep @login",
    "tag:addBook": "wdio --mochaOpts.grep @addBook",
    "tag:delBook": "wdio --mochaOpts.grep @deleteBook",
    "tag:register": "wdio --mochaOpts.grep @register",
    "tag:smoke": "wdio --mochaOpts.grep @smoke",
    "tag:flaky": "wdio --mochaOpts.grep @flaky --mochaOpts.invert",
    "regression": "wdio --suite regression",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@wdio/allure-reporter": "^9.29.1",
    "@wdio/cli": "^9.29.1",
    "@wdio/globals": "^9.29.1",
    "@wdio/local-runner": "^9.29.1",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "allure-commandline": "^2.43.0",
    "axios": "^1.18.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "expect-webdriverio": "^5.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "prettier-eslint": "^17.1.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "cross-env": "^10.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
